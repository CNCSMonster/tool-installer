#!/usr/bin/env python3
"""Build the tool-installer single-file executable artifact.

The artifact is a compressed Python zip application with a shebang.  It uses
only the host Python interpreter and includes the package's vendored TOML
fallback, so it does not require runtime packages from PyPI.
"""

from __future__ import annotations

import argparse
import os
import shutil
import stat
import subprocess
import sys
import tempfile
import zipfile
from pathlib import Path
from typing import Optional

MAX_ARTIFACT_BYTES = 400 * 1024
SHEBANG = b"#!/usr/bin/env python3\n"
ZIP_TIMESTAMP = (1980, 1, 1, 0, 0, 0)


def parse_args() -> argparse.Namespace:
    repo_root = Path(__file__).resolve().parents[1]
    parser = argparse.ArgumentParser(description="build the single-file tool-installer executable")
    parser.add_argument(
        "--output",
        default=str(repo_root / "dist" / "tool-installer"),
        help="output artifact path (default: dist/tool-installer)",
    )
    parser.add_argument(
        "--source",
        default=str(repo_root / "src"),
        help="source package root (default: src)",
    )
    parser.add_argument(
        "--max-bytes",
        type=int,
        default=MAX_ARTIFACT_BYTES,
        help="maximum allowed artifact size in bytes (default: 409600)",
    )
    parser.add_argument(
        "--no-verify",
        action="store_true",
        help="build only; skip executable/help/example dry-run verification",
    )
    return parser.parse_args()


def iter_python_files(package_root: Path):
    for path in sorted(package_root.rglob("*.py")):
        if "__pycache__" in path.parts:
            continue
        yield path


def zip_info(name: str, mode: int = 0o644) -> zipfile.ZipInfo:
    info = zipfile.ZipInfo(name, ZIP_TIMESTAMP)
    info.compress_type = zipfile.ZIP_DEFLATED
    info.external_attr = (stat.S_IFREG | mode) << 16
    return info


def build_artifact(source_root: Path, output: Path, max_bytes: int) -> int:
    package_root = source_root / "tool_installer"
    if not package_root.is_dir():
        raise SystemExit(f"package directory not found: {package_root}")

    output.parent.mkdir(parents=True, exist_ok=True)

    with tempfile.NamedTemporaryFile("wb", delete=False, dir=str(output.parent), prefix=output.name + ".tmp.") as tmp:
        tmp_path = Path(tmp.name)
        tmp.write(SHEBANG)
        with zipfile.ZipFile(tmp, "w", compression=zipfile.ZIP_DEFLATED, compresslevel=9) as zf:
            zf.writestr(
                zip_info("__main__.py"),
                "from tool_installer.cli import main\nraise SystemExit(main())\n",
            )
            for path in iter_python_files(package_root):
                arcname = path.relative_to(source_root).as_posix()
                zf.writestr(zip_info(arcname), path.read_bytes())

    os.chmod(tmp_path, 0o755)
    size = tmp_path.stat().st_size
    if size > max_bytes:
        tmp_path.unlink(missing_ok=True)
        raise SystemExit(f"artifact is too large: {size} bytes > {max_bytes} bytes")

    os.replace(tmp_path, output)
    os.chmod(output, 0o755)
    return size


def run_checked(args, *, cwd: Optional[Path] = None) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        list(map(str, args)),
        cwd=str(cwd) if cwd is not None else None,
        check=True,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def verify_artifact(repo_root: Path, output: Path, max_bytes: int) -> None:
    if not output.is_file():
        raise SystemExit(f"artifact not found: {output}")
    if not os.access(output, os.X_OK):
        raise SystemExit(f"artifact is not executable: {output}")
    size = output.stat().st_size
    if size > max_bytes:
        raise SystemExit(f"artifact is too large: {size} bytes > {max_bytes} bytes")

    help_result = run_checked([output, "--help"])
    if "install" not in help_result.stdout:
        raise SystemExit("artifact help output does not include the install command")

    examples_dir = repo_root / "examples"
    dry_run = run_checked([output, "install", "dev", "--dry-run"], cwd=examples_dir)
    if "PLAN " not in dry_run.stdout or "example-script" not in dry_run.stdout:
        raise SystemExit("artifact example dry-run output did not include the expected plan")


def main() -> int:
    args = parse_args()
    repo_root = Path(__file__).resolve().parents[1]
    source_root = Path(args.source).resolve()
    output = Path(args.output).resolve()

    if not shutil.which("python3"):
        raise SystemExit("python3 is required to execute the generated artifact")

    size = build_artifact(source_root, output, args.max_bytes)
    if not args.no_verify:
        verify_artifact(repo_root, output, args.max_bytes)
    print(f"built {output} ({size} bytes)")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
